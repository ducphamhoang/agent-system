# agent-system environment configuration
# Copy this file to .env and edit values as needed.
# The .env file is gitignored — never commit it with real values.

# Claude model to use for agent tasks.
# Must match pattern: claude-* (e.g. claude-opus-4-7, claude-sonnet-4-5)
AGENT_SYSTEM_MODEL=claude-opus-4-7

# Request timeout in seconds. Must be a positive integer.
AGENT_SYSTEM_TIMEOUT=30

# Maximum retry attempts on transient failures. Range: 0-10.
AGENT_SYSTEM_MAX_RETRIES=3
